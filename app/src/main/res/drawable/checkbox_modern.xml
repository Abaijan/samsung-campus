<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Checked state - Blue with white checkmark -->
    <item android:state_checked="true">
        <layer-list>
            <!-- Background -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#2196F3"/>
                    <corners android:radius="4dp"/>
                </shape>
            </item>

            <!-- White checkmark using rotated L shape -->
            <item>
                <rotate
                    android:fromDegrees="45"
                    android:pivotX="30%"
                    android:pivotY="65%">
                    <layer-list>
                        <!-- Short part -->
                        <item android:left="7dp" android:top="9dp">
                            <shape android:shape="rectangle">
                                <solid android:color="#FFFFFF"/>
                                <size android:width="2.5dp" android:height="6dp"/>
                                <corners android:radius="1dp"/>
                            </shape>
                        </item>
                        <!-- Long part -->
                        <item android:left="7dp" android:top="3dp">
                            <shape android:shape="rectangle">
                                <solid android:color="#FFFFFF"/>
                                <size android:width="2.5dp" android:height="12dp"/>
                                <corners android:radius="1dp"/>
                            </shape>
                        </item>
                    </layer-list>
                </rotate>
            </item>
        </layer-list>
    </item>

    <!-- Pressed unchecked -->
    <item android:state_pressed="true" android:state_checked="false">
        <shape android:shape="rectangle">
            <stroke android:width="2dp" android:color="#2196F3"/>
            <solid android:color="#E3F2FD"/>
            <corners android:radius="4dp"/>
        </shape>
    </item>

    <!-- Unchecked -->
    <item android:state_checked="false">
        <shape android:shape="rectangle">
            <stroke android:width="2dp" android:color="#BDBDBD"/>
            <solid android:color="#FFFFFF"/>
            <corners android:radius="4dp"/>
        </shape>
    </item>

</selector>