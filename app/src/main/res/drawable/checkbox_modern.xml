<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Отмечен - оранжевый фон с белой галочкой -->
    <item android:state_checked="true">
        <layer-list>
            <!-- Оранжевый фон с бордером -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#E95B22"/>
                    <stroke android:width="2dp" android:color="#D14A15"/>
                    <corners android:radius="4dp"/>
                    <size android:width="24dp" android:height="24dp"/>
                </shape>
            </item>

            <!-- Белая галочка -->
            <item
                android:top="4dp"
                android:bottom="4dp"
                android:left="4dp"
                android:right="4dp">
                <vector
                    android:width="24dp"
                    android:height="24dp"
                    android:viewportWidth="24"
                    android:viewportHeight="24">
                    <path
                        android:fillColor="#FFFFFF"
                        android:pathData="M9,16.17L4.83,12l-1.42,1.41L9,19 21,7l-1.41,-1.41z"/>
                </vector>
            </item>
        </layer-list>
    </item>

    <!-- Не отмечен - белый фон с серым бордером -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="2dp" android:color="#757575"/>
            <solid android:color="#FFFFFF"/>
            <corners android:radius="4dp"/>
            <size android:width="32dp" android:height="32dp"/>
        </shape>
    </item>

</selector>