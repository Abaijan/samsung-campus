<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Checked state - Modern blue gradient -->
    <item android:state_checked="true">
        <layer-list>
            <!-- Shadow/elevation effect -->
            <item android:top="1dp" android:left="1dp">
                <shape android:shape="rectangle">
                    <solid android:color="#20000000"/>
                    <corners android:radius="7dp"/>
                </shape>
            </item>
            
            <!-- Background gradient -->
            <item android:bottom="1dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="135"
                        android:startColor="#2196F3"
                        android:centerColor="#1E88E5"
                        android:endColor="#1976D2"
                        android:type="linear"/>
                    <corners android:radius="6dp"/>
                </shape>
            </item>
            
            <!-- White checkmark - L shape rotated -->
            <item android:bottom="1dp" android:right="1dp">
                <rotate
                    android:fromDegrees="45"
                    android:pivotX="30%"
                    android:pivotY="65%">
                    <layer-list>
                        <!-- Short part of checkmark -->
                        <item android:left="8dp" android:top="10dp">
                            <shape android:shape="rectangle">
                                <solid android:color="#FFFFFF"/>
                                <size android:width="3dp" android:height="7dp"/>
                                <corners android:radius="1.5dp"/>
                            </shape>
                        </item>
                        <!-- Long part of checkmark -->
                        <item android:left="8dp" android:top="4dp">
                            <shape android:shape="rectangle">
                                <solid android:color="#FFFFFF"/>
                                <size android:width="3dp" android:height="13dp"/>
                                <corners android:radius="1.5dp"/>
                            </shape>
                        </item>
                    </layer-list>
                </rotate>
            </item>
        </layer-list>
    </item>

    <!-- Pressed unchecked state -->
    <item android:state_pressed="true" android:state_checked="false">
        <layer-list>
            <!-- Shadow -->
            <item android:top="1dp" android:left="1dp">
                <shape android:shape="rectangle">
                    <solid android:color="#20000000"/>
                    <corners android:radius="7dp"/>
                </shape>
            </item>
            
            <!-- Background -->
            <item android:bottom="1dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <stroke android:width="2.5dp" android:color="#2196F3"/>
                    <solid android:color="#E3F2FD"/>
                    <corners android:radius="6dp"/>
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Unchecked state -->
    <item android:state_checked="false">
        <layer-list>
            <!-- Subtle shadow -->
            <item android:top="1dp" android:left="1dp">
                <shape android:shape="rectangle">
                    <solid android:color="#10000000"/>
                    <corners android:radius="7dp"/>
                </shape>
            </item>
            
            <!-- Border -->
            <item android:bottom="1dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <stroke android:width="2.5dp" android:color="#BDBDBD"/>
                    <solid android:color="#FFFFFF"/>
                    <corners android:radius="6dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    
</selector>
