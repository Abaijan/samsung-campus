<?xml version="1.0" encoding="utf-8"?>
<!-- Modern details screen with ALL original IDs preserved -->
<ScrollView
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:background="@color/background"
	android:layout_height="fill_parent"
	android:layout_width="fill_parent"
	android:scrollbars="vertical"
	android:scrollbarAlwaysDrawVerticalTrack="false"
	android:padding="16dp">

	<LinearLayout
		android:id="@+id/LinearLayout00"
		android:layout_height="wrap_content"
		android:layout_width="fill_parent"
		android:orientation="vertical">

		<!-- Description Card -->
		<LinearLayout
			android:layout_width="fill_parent"
			android:layout_height="wrap_content"
			android:background="@drawable/card_background"
			android:padding="16dp"
			android:orientation="vertical"
			android:layout_marginBottom="12dp">

			<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Task Description"
				android:textSize="12sp"
				android:textColor="@color/text_secondary"
				android:textStyle="bold"
				android:layout_marginBottom="8dp"/>

			<EditText
				android:hint="@string/DetailDescriptionPlaceholder"
				android:id="@+id/DetailEditTextDescription"
				android:layout_width="fill_parent"
				android:layout_height="wrap_content"
				android:background="@drawable/edittext_background"
				android:inputType="text|textCapSentences|textMultiLine"
				android:textSize="16sp"
				android:textColor="@color/text_primary"
				android:textColorHint="@color/text_secondary"
				android:minLines="2"
				android:gravity="top">
				<requestFocus/>
			</EditText>
		</LinearLayout>

		<!-- TableLayout for all rows -->
		<LinearLayout
			android:id="@+id/TableLayout01"
			android:layout_width="fill_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">

			<!-- Priority Card -->
			<LinearLayout
				android:id="@+id/TableRow01"
				android:layout_width="fill_parent"
				android:layout_height="wrap_content"
				android:background="@drawable/card_background"
				android:padding="16dp"
				android:orientation="vertical"
				android:layout_marginBottom="12dp">

				<TextView
					android:text="@string/DetailTextPriority"
					android:id="@+id/DetailTextPriority"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:textColor="@color/text_secondary"
					android:textSize="12sp"
					android:textStyle="bold"
					android:layout_marginBottom="8dp"/>

				<LinearLayout
					android:id="@+id/LinearLayout01"
					android:layout_height="wrap_content"
					android:orientation="horizontal"
					android:layout_width="fill_parent">

					<EditText
						android:id="@+id/DetailEditTextPriority"
						android:layout_width="fill_parent"
						android:layout_height="wrap_content"
						android:hint="8"
						android:background="@drawable/edittext_background"
						android:inputType="number"
						android:textSize="16sp"
						android:textColor="@color/text_primary"
						android:textColorHint="@color/text_secondary"/>
				</LinearLayout>
			</LinearLayout>

			<!-- Category Card -->
			<LinearLayout
				android:id="@+id/CategoryTableRow"
				android:layout_width="fill_parent"
				android:layout_height="wrap_content"
				android:background="@drawable/card_background"
				android:padding="16dp"
				android:orientation="vertical"
				android:layout_marginBottom="12dp">

				<TextView
					android:text="@string/DetailTextCategory"
					android:id="@+id/DetailTextCategory"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:textColor="@color/text_secondary"
					android:textSize="12sp"
					android:textStyle="bold"
					android:layout_marginBottom="8dp"/>

				<LinearLayout
					android:id="@+id/LinearLayout02"
					android:layout_height="wrap_content"
					android:orientation="horizontal"
					android:layout_width="fill_parent">

					<Spinner
						android:layout_height="wrap_content"
						android:layout_width="fill_parent"
						android:background="@drawable/edittext_background"
						android:id="@+id/DetailSpinnerCategory"/>
				</LinearLayout>
			</LinearLayout>

			<!-- Last Completed Card -->
			<LinearLayout
				android:id="@+id/LastCompletedTableRow"
				android:layout_width="fill_parent"
				android:layout_height="wrap_content"
				android:background="@drawable/card_background"
				android:padding="16dp"
				android:orientation="vertical"
				android:layout_marginBottom="12dp">

				<TextView
					android:text="@string/DetailTextCompleted"
					android:id="@+id/DetailTextCompleted"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:textColor="@color/text_secondary"
					android:textSize="12sp"
					android:textStyle="bold"
					android:layout_marginBottom="8dp"/>

				<LinearLayout
					android:id="@+id/LinearLayout03"
					android:layout_height="wrap_content"
					android:orientation="horizontal"
					android:layout_width="fill_parent">

					<TextView
						android:layout_height="wrap_content"
						android:layout_width="fill_parent"
						android:id="@+id/DetailTextCompletedDate"
						android:background="@drawable/date_badge"
						android:textSize="14sp"
						android:textColor="@color/text_primary"
						android:gravity="center_vertical"
						android:minHeight="44dp"/>
				</LinearLayout>
			</LinearLayout>

			<!-- Due Date Card -->
			<LinearLayout
				android:id="@+id/DueDateTableRow"
				android:layout_width="fill_parent"
				android:layout_height="wrap_content"
				android:background="@drawable/card_background"
				android:padding="16dp"
				android:orientation="vertical"
				android:layout_marginBottom="12dp"
				android:clickable="true">

				<TextView
					android:text="@string/DetailTextDueDate"
					android:id="@+id/DetailTextDueDate"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:textColor="@color/text_secondary"
					android:textSize="12sp"
					android:textStyle="bold"
					android:layout_marginBottom="8dp"/>

				<LinearLayout
					android:id="@+id/LinearLayout04"
					android:layout_height="wrap_content"
					android:orientation="horizontal"
					android:layout_width="fill_parent">

					<Button
						android:id="@+id/DetailButtonDueDate"
						android:layout_width="fill_parent"
						android:layout_height="wrap_content"
						android:background="@drawable/button_secondary"
						android:textColor="@color/primary"
						android:textSize="14sp"
						android:minHeight="44dp"/>
				</LinearLayout>
			</LinearLayout>

			<!-- Hide Until Card -->
			<LinearLayout
				android:id="@+id/HideTableRow"
				android:layout_width="fill_parent"
				android:layout_height="wrap_content"
				android:background="@drawable/card_background"
				android:padding="16dp"
				android:orientation="vertical"
				android:layout_marginBottom="12dp">

				<TextView
					android:text="@string/DetailTextHideUntil"
					android:id="@+id/DetailTextHideUntil"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:textColor="@color/text_secondary"
					android:textSize="12sp"
					android:textStyle="bold"
					android:layout_marginBottom="8dp"/>

				<LinearLayout
					android:id="@+id/LinearLayout05"
					android:layout_height="wrap_content"
					android:orientation="horizontal"
					android:layout_width="fill_parent">

					<Button
						android:id="@+id/DetailButtonHideUntil"
						android:layout_width="fill_parent"
						android:layout_height="wrap_content"
						android:background="@drawable/button_secondary"
						android:textColor="@color/primary"
						android:textSize="14sp"
						android:minHeight="44dp"/>
				</LinearLayout>
			</LinearLayout>

			<!-- Alarm Card -->
			<LinearLayout
				android:id="@+id/AlarmTableRow"
				android:layout_width="fill_parent"
				android:layout_height="wrap_content"
				android:background="@drawable/card_background"
				android:padding="16dp"
				android:orientation="vertical"
				android:layout_marginBottom="12dp">

				<TextView
					android:text="@string/DetailTextAlarm"
					android:id="@+id/DetailTextAlarm"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:textColor="@color/text_secondary"
					android:textSize="12sp"
					android:textStyle="bold"
					android:layout_marginBottom="8dp"/>

				<LinearLayout
					android:id="@+id/LinearLayout06"
					android:layout_height="wrap_content"
					android:orientation="horizontal"
					android:layout_width="fill_parent">

					<Button
						android:id="@+id/DetailButtonAlarm"
						android:layout_width="fill_parent"
						android:layout_height="wrap_content"
						android:background="@drawable/button_secondary"
						android:textColor="@color/primary"
						android:textSize="14sp"
						android:minHeight="44dp"/>
				</LinearLayout>
			</LinearLayout>

			<!-- Repeat Card -->
			<LinearLayout
				android:id="@+id/RepeatTableRow"
				android:layout_width="fill_parent"
				android:layout_height="wrap_content"
				android:background="@drawable/card_background"
				android:padding="16dp"
				android:orientation="vertical"
				android:layout_marginBottom="12dp">

				<TextView
					android:text="@string/DetailTextRepeat"
					android:id="@+id/DetailTextRepeat"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:textColor="@color/text_secondary"
					android:textSize="12sp"
					android:textStyle="bold"
					android:layout_marginBottom="8dp"/>

				<LinearLayout
					android:id="@+id/LinearLayout07"
					android:layout_height="wrap_content"
					android:orientation="horizontal"
					android:layout_width="fill_parent">

					<Button
						android:id="@+id/DetailButtonRepeat"
						android:layout_width="fill_parent"
						android:layout_height="wrap_content"
						android:background="@drawable/button_secondary"
						android:textColor="@color/primary"
						android:textSize="14sp"
						android:minHeight="44dp"/>
				</LinearLayout>
			</LinearLayout>

			<!-- Private Card -->
			<LinearLayout
				android:id="@+id/PrivateTableRow"
				android:layout_width="fill_parent"
				android:layout_height="wrap_content"
				android:background="@drawable/card_background"
				android:padding="16dp"
				android:orientation="vertical"
				android:layout_marginBottom="12dp">

				<TextView
					android:text="@string/DetailTextPrivate"
					android:id="@+id/DetailTextPrivate"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:textColor="@color/text_secondary"
					android:textSize="12sp"
					android:textStyle="bold"
					android:layout_marginBottom="8dp"/>

				<LinearLayout
					android:id="@+id/LinearLayout08"
					android:layout_height="wrap_content"
					android:orientation="horizontal"
					android:layout_width="fill_parent">

					<CheckBox
						android:id="@+id/DetailCheckBoxPrivate"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:button="@drawable/checkbox_modern"
						android:scaleX="1.2"
						android:scaleY="1.2"/>
				</LinearLayout>
			</LinearLayout>
		</LinearLayout>

		<!-- Action Buttons -->
		<LinearLayout
			android:id="@+id/LinearLayout09"
			android:layout_width="fill_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:layout_marginTop="8dp">

			<Button
				android:text="@string/DetailButtonOK"
				android:id="@+id/DetailButtonOK"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:background="@drawable/button_primary"
				android:textColor="#FFFFFF"
				android:textStyle="bold"
				android:textSize="16sp"
				android:minHeight="48dp"
				android:layout_marginRight="8dp"/>

			<Button
				android:text="@string/DetailButtonCancel"
				android:id="@+id/DetailButtonCancel"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:background="@drawable/button_secondary"
				android:textColor="@color/primary"
				android:textSize="16sp"
				android:minHeight="48dp"
				android:layout_marginRight="8dp"/>

			<Button
				android:text="@string/DetailButtonDelete"
				android:id="@+id/DetailButtonDelete"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:background="@drawable/button_danger"
				android:textColor="#FFFFFF"
				android:textSize="16sp"
				android:minHeight="48dp"
				android:layout_marginRight="8dp"/>

			<ImageButton
				android:id="@+id/DetailButtonNote"
				android:layout_width="48dp"
				android:layout_height="48dp"
				android:src="@drawable/postit"
				android:background="@drawable/button_secondary"
				android:scaleType="centerInside"
				android:padding="12dp"
				android:tint="@color/accent"/>
		</LinearLayout>
	</LinearLayout>
</ScrollView>