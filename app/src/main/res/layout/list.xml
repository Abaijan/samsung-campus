<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	android:orientation="vertical"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="#F5F5F5">

	<!-- Modern Header with gradient background -->
	<LinearLayout
		android:id="@+id/HeaderLayout"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:background="@drawable/header_gradient"
		android:elevation="4dp"
		android:padding="16dp">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:gravity="center_vertical">

			<!-- New Task Button with modern style -->
			<Button
				android:id="@+id/ListButtonNew"
				android:text="@string/ListButtonNew"
				android:layout_width="0dp"
				android:layout_height="48dp"
				android:layout_weight="1"
				android:background="@drawable/button_modern"
				android:textColor="@color/white"
				android:textStyle="bold"
				android:textSize="16sp"
				android:elevation="2dp"
				android:layout_marginEnd="12dp"/>

			<!-- Category Spinner with card style -->
			<Spinner
				android:id="@+id/ListSpinnerCategory"
				android:layout_width="0dp"
				android:layout_height="48dp"
				android:layout_weight="2"
				android:background="@drawable/spinner_modern"
				android:padding="12dp"
				android:elevation="2dp"
				android:entries="@array/CategoryFilterList"/>
		</LinearLayout>
	</LinearLayout>

	<!-- Task List with padding for card effect -->
	<ListView
		android:id="@android:id/list"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:divider="@android:color/transparent"
		android:dividerHeight="8dp"
		android:padding="12dp"
		android:clipToPadding="false"
		android:scrollbarStyle="outsideOverlay"/>

</LinearLayout>